#!/usr/bin/env python3
"""Wrapper entrypoint for defora_cli.deforumation_runs_cli (curses UI)."""
import sys
from pathlib import Path

sys.path.insert(0, str(Path(__file__).resolve().parents[1]))

import curses
from defora_cli import deforumation_runs_cli as _runs


def _main():
    curses.wrapper(_runs.main)


if __name__ == "__main__":
    _main()
