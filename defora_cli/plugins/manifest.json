{
  "plugins": [
    {
      "name": "audio_post_identity",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Pass-through audio post-processing plugin",
      "plugin_type": "post-process",
      "entry_point": "defora_cli.plugins.audio_post:process",
      "tags": ["audio", "post-process"]
    },
    {
      "name": "audio_post_clamp",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Clamp audio output values to safe range",
      "plugin_type": "post-process",
      "entry_point": "defora_cli.plugins.audio_post:clamp_outputs",
      "parameters": {
        "limit": 1.5
      },
      "tags": ["audio", "post-process", "safety"]
    },
    {
      "name": "smooth_modulator",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Smooth parameter modulation with configurable smoothing",
      "plugin_type": "modulator",
      "entry_point": "defora_cli.plugins.plugin_system:SmoothModulator",
      "parameters": {
        "smoothing": 0.5
      },
      "tags": ["modulator", "smooth"]
    },
    {
      "name": "step_modulator",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Quantize parameter values to discrete steps",
      "plugin_type": "modulator",
      "entry_point": "defora_cli.plugins.plugin_system:StepModulator",
      "parameters": {
        "steps": 8,
        "min": 0.0,
        "max": 1.0
      },
      "tags": ["modulator", "step", "quantize"]
    },
    {
      "name": "random_modulator",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Add controlled random variance to parameters",
      "plugin_type": "modulator",
      "entry_point": "defora_cli.plugins.plugin_system:RandomModulator",
      "parameters": {
        "variance": 0.1
      },
      "tags": ["modulator", "random", "variance"]
    },
    {
      "name": "exponential_mapping",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Exponential parameter mapping curve",
      "plugin_type": "mapper",
      "entry_point": "defora_cli.plugins.plugin_system:ExponentialMapping",
      "tags": ["mapping", "exponential"]
    },
    {
      "name": "logarithmic_mapping",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "Logarithmic parameter mapping curve",
      "plugin_type": "mapper",
      "entry_point": "defora_cli.plugins.plugin_system:LogarithmicMapping",
      "tags": ["mapping", "logarithmic"]
    },
    {
      "name": "sigmoid_mapping",
      "version": "0.1.0",
      "author": "Defora Team",
      "description": "S-curve parameter mapping for smooth transitions",
      "plugin_type": "mapper",
      "entry_point": "defora_cli.plugins.plugin_system:SigmoidMapping",
      "tags": ["mapping", "sigmoid", "s-curve"]
    }
  ]
}
